# ---------- App ----------
APP_NAME="ExpenseOps Agent"
DATABASE_URL="sqlite:///./expenseops.db"
ENVIRONMENT="local" # local | production
ENABLE_DOCS=false
FRONTEND_ORIGIN="http://localhost:5173"

# Required in production. In local dev, auth is disabled if these are blank.
DASHBOARD_USERNAME=""
DASHBOARD_PASSWORD=""
DASHBOARD_API_TOKEN=""

# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_SECRET_KEY="paste-a-generated-fernet-key-here"

# Production Plaid webhooks require verification even if this is false.
# Set true in local sandbox/dev if you want to exercise Plaid JWT verification.
PLAID_VERIFY_WEBHOOKS=false
# Temporary local-only production webhook test bypass. Never set this true in
# deployed production. It is honored only with PLAID_ENV=production and a local
# APP_ENV/ENVIRONMENT.
ALLOW_UNVERIFIED_PLAID_WEBHOOKS_FOR_LOCAL_TEST=false
ALLOW_POSTING_PENDING_TRANSACTIONS=false

# ---------- Plaid ----------
# Create a Plaid app and use sandbox first.
PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV="sandbox"   # sandbox | development | production
PLAID_WEBHOOK_URL=""  # e.g. https://your-ngrok-url.ngrok-free.app/plaid/webhook
PLAID_COUNTRY_CODES="US"
PLAID_PRODUCTS="transactions"
PLAID_DAYS_REQUESTED=30

# ---------- Splitwise ----------
SPLITWISE_BASE_URL="https://secure.splitwise.com/api/v3.0"

# Paste the API key generated from your Splitwise app.
SPLITWISE_API_KEY=""

# Leave bearer/OAuth fields blank when using SPLITWISE_API_KEY.
SPLITWISE_ACCESS_TOKEN=""
SPLITWISE_AUTH_SCHEME="Bearer"

# Optional OAuth 1.0 fallback.
SPLITWISE_CONSUMER_KEY=""
SPLITWISE_CONSUMER_SECRET=""
SPLITWISE_OAUTH_CALLBACK_URL="http://localhost:8000/splitwise/oauth/callback"
SPLITWISE_OAUTH_TOKEN=""
SPLITWISE_OAUTH_TOKEN_SECRET=""

# ---------- Telegram ----------
# Optional notification bot. Console logging works without these.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
TELEGRAM_WEBHOOK_SECRET=""
TELEGRAM_ALLOWED_USER_ID=""

# ---------- OpenAI ----------
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
